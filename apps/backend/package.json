{
  "name": "@pl-jobhunter/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:init": "tsx src/config/init-db.ts",
    "etl:run": "tsx src/scheduler/etl.ts --run-once",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@pl-jobhunter/shared": "workspace:*",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "node-cron": "^3.0.3",
    "oracledb": "^6.7.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/oracledb": "^7.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "msw": "^2.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
