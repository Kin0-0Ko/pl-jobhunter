# Oracle Autonomous DB
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_CONNECTION_STRING=your_connection_string
TNS_ADMIN=./wallet
DB_WALLET_PASSWORD=

# Fastify server
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
# Set NODE_ENV=development (default) to enable pino-pretty output in dev

# API auth (shared secret between frontend and backend)
API_TOKEN=your_secret_token_here

# Telegram bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_chat_id

# Ollama AI scorer
OLLAMA_BASE_URL=http://127.0.0.1:11434
# qwen2.5:0.5b is the default for 1 GB RAM Oracle Always Free — uses ~300 MB vs ~3 GB for larger models
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_USER_PROFILE=Senior TypeScript developer, 5 years Node.js, interested in remote B2B roles in Poland
# Set in Ollama container environment to unload model from RAM immediately after each request
# OLLAMA_KEEP_ALIVE=0

# Alert threshold (0-100)
ALERT_SCORE_THRESHOLD=80

# ETL batching — process scraped jobs in chunks to bound peak RSS on the 1 GB Oracle Always Free instance
# Lower values = less memory pressure; higher values = fewer DB round-trips. Default 50.
ETL_CHUNK_SIZE=50
# Recommended Node.js heap cap for the ETL process on 1 GB VPS:
# node --max-old-space-size=256 dist/scheduler/etl.js --run-once

# ETL fault-tolerance: number of consecutive per-job DB write failures before the run aborts.
# A single transient failure still skips only that one job and continues. Default 10.
ETL_DB_FAILURE_ABORT_THRESHOLD=10

# Shared description cap used by both the JustJoin detail fetch and the Ollama Pass-1 prompt.
# Raising this increases scoring context at the cost of slightly larger prompts. Default 2000.
SCORING_DESC_MAX_CHARS=2000

# Maximum milliseconds to wait for a single Ollama API call before aborting and using the
# fallback record. Prevents a hung model from stalling the entire ETL run. Default 60000.
OLLAMA_TIMEOUT_MS=60000

# AI provider toggle: 'ollama' (default, local) or 'nvidia' (cloud, OpenAI-compatible endpoint)
AI_PROVIDER=ollama

# NVIDIA NIM cloud AI scorer (only used when AI_PROVIDER=nvidia)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm-5.2
# Maximum milliseconds to wait for a single NVIDIA API call before aborting and using the
# fallback record. Default 60000.
NVIDIA_TIMEOUT_MS=60000
